{
  "name": "anoosh-mobile",
  "version": "1.0.0",
  "description": "Anoosh for Android — offline productivity that syncs with the desktop app.",
  "private": true,
  "scripts": {
    "assets": "node scripts/copy-shared.js",
    "native": "node scripts/install-native.js",
    "sync": "npm run assets && npx cap sync android && npm run native",
    "apk": "cd android && gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.2",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/share": "^6.0.2",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
