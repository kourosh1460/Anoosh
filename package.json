{
  "name": "anoosh-productivity",
  "productName": "Anoosh",
  "version": "2.3.0",
  "description": "Anoosh — an offline, native Windows productivity suite: tasks, notes in folders, ideas, calendar (Gregorian + Hijri lunar + Jalali solar), reminders and timers in one connected system.",
  "main": "main.js",
  "author": "Anoosh",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test \"tests/*.test.js\"",
    "selftest": "cmd /c \"set ANOOSH_SELFTEST=1&& electron .\"",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.anoosh.productivity",
    "productName": "Anoosh",
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": false,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "build/icon.ico"
    ]
  }
}
